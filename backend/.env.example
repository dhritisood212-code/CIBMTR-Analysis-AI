# Copy to .env and fill in. The app STARTS without these but any run fails fast with a clear
# message telling you which one is missing.

# --- Anthropic API (required to run the agent panel) ---
ANTHROPIC_API_KEY=

# Model per agent. Not hardcoded to a single version on purpose - check
# https://docs.claude.com for the current model list before pinning production values.
# Harder reasoning roles default to a stronger model; mechanical roles to a faster one.
INTERPRETER_MODEL=claude-opus-4-8
BUILDER_MODEL=claude-sonnet-5
ASSEMBLER_MODEL=claude-sonnet-5
ANALYST_MODEL=claude-opus-4-8
COMPARATOR_MODEL=claude-sonnet-5
DIAGNOSER_MODEL=claude-opus-4-8
MAX_TOKENS=8192

# --- Sandboxed R runtime (required to execute agent-produced R) ---
# Command the R runner invokes. See infra/README.md for the container contract.
R_SANDBOX_CMD=infra/run_r_sandboxed.sh
R_TIMEOUT_SECONDS=300
R_MAX_MEMORY_MB=4096

# --- Reproduction loop ---
MAX_DIAGNOSE_ITERATIONS=2
ITERATE_ON_PARTIAL=false

# --- Tolerances (defaults from the brief; all configurable) ---
TOL_COHORT_N_REL=0.05          # +-5%
TOL_TABLE1_PROP_PTS=0.03       # +-3 percentage points
TOL_MEDIAN_MONTHS=2.0          # +-2 months
TOL_CIF_KM_ABS=0.02            # +-0.02 absolute
TOL_HR_REL=0.10                # +-10% relative

# --- Storage / sessions ---
RUNS_DIR=./runs                # persistent: artifacts + match reports ONLY
SESSION_DATA_TTL_MINUTES=120   # user datasets deleted on session end / after TTL
